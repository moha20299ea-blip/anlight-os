#!/bin/sh
# Anlight OS - live-build configuration
# A lightweight, elegant Debian-based cybersecurity distro.
set -e

lb config noauto \
	--mode debian \
	--distribution bookworm \
	--architectures amd64 \
	--binary-images iso-hybrid \
	--debian-installer live \
	--archive-areas "main contrib non-free non-free-firmware" \
	--apt-recommends false \
	--bootappend-live "boot=live components quiet splash username=anlight hostname=anlight" \
	--iso-application "Anlight OS" \
	--iso-publisher "Aegis Raid" \
	--iso-volume "Anlight OS" \
	"${@}"
