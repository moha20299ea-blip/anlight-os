#!/bin/sh
# Anlight OS - desktop session bootstrap (wallpaper, compositor, dock, widgets, chime)

# guarantee the aurora wallpaper on every monitor (don't trust a default backdrop)
(
  sleep 1
  for p in $(xfconf-query -c xfce4-desktop -l 2>/dev/null | grep -E 'last-image$'); do
    xfconf-query -c xfce4-desktop -p "$p" -s /usr/share/backgrounds/anlight/aurora.png 2>/dev/null
  done
  feh --bg-fill /usr/share/backgrounds/anlight/aurora.png 2>/dev/null
) &

# liquid-glass compositor
pkill -x picom 2>/dev/null
picom --config "$HOME/.config/picom/picom.conf" -b &

# floating glass dock
( sleep 1; plank ) &

# desktop widget HUD
( sleep 2; conky -c "$HOME/.config/conky/conky.conf" ) &

# startup chime (then silence)
( sleep 2; paplay /usr/share/sounds/anlight/startup.oga 2>/dev/null ) &

# welcome notification
( sleep 5; notify-send -i /usr/share/backgrounds/anlight/logo.png \
    "Welcome to Anlight OS" \
    "by Aegis Raid Corp.  ·  type  anlight-get <package | github-url>  to install anything." ) &

exit 0
