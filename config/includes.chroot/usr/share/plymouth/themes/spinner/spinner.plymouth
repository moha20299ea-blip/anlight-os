[Plymouth Theme]
Name=Anlight Spinner
Description=Anlight OS spinning boot
ModuleName=two-step

[two-step]
ImageDir=/usr/share/plymouth/themes/spinner
HorizontalAlignment=.5
VerticalAlignment=.5
WatermarkHorizontalAlignment=.5
WatermarkVerticalAlignment=.85
Transition=none
TransitionDuration=0.0
BackgroundStartColor=0x0a0a14
BackgroundEndColor=0x05060e
DialogHorizontalAlignment=.5
DialogVerticalAlignment=.5
