#!/bin/sh
# Anlight OS - activate the custom Plymouth boot theme + clean (textless) boot
set -e

if command -v plymouth-set-default-theme >/dev/null 2>&1; then
    plymouth-set-default-theme anlight || true
fi

# make sure the frames are pulled into the initramfs
if command -v update-initramfs >/dev/null 2>&1; then
    update-initramfs -u || true
fi
